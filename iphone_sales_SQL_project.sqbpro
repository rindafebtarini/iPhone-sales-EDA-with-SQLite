Pertanyaan Umum
-- 1.Berapa jumlah total transaksi pada dataset penjualan iPhone?
SELECT COUNT(*) AS total_transaksi
FROM iphone_sales_dataset;

-- 2.Apa rentang tanggal penjualan pada dataset?
SELECT 
    MIN(Sale_Date) AS tanggal_awal,
    MAX(Sale_Date) AS tanggal_akhir
FROM iphone_sales_dataset;

-- 3. Apakah terdapat missing value pada dataset?
SELECT
    SUM(CASE WHEN Order_ID IS NULL THEN 1 ELSE 0 END) AS missing_order_id,
    SUM(CASE WHEN Customer_Name IS NULL THEN 1 ELSE 0 END) AS missing_customer_name,
    SUM(CASE WHEN Country IS NULL THEN 1 ELSE 0 END) AS missing_country,
    SUM(CASE WHEN iPhone_Model IS NULL THEN 1 ELSE 0 END) AS missing_iphone_model,
    SUM(CASE WHEN Storage IS NULL THEN 1 ELSE 0 END) AS missing_storage,
    SUM(CASE WHEN Color IS NULL THEN 1 ELSE 0 END) AS missing_color,
    SUM(CASE WHEN Quantity IS NULL THEN 1 ELSE 0 END) AS missing_quantity,
    SUM(CASE WHEN Price IS NULL THEN 1 ELSE 0 END) AS missing_price,
    SUM(CASE WHEN Sale_Date IS NULL THEN 1 ELSE 0 END) AS missing_sale_date,
    SUM(CASE WHEN Payment_Method IS NULL THEN 1 ELSE 0 END) AS missing_payment_method
FROM iphone_sales_dataset;

-- 4. Kolom apa saja yang tersedia pada dataset penjualan iPhone?
PRAGMA table_info(iphone_sales_dataset);

Analisis Penjualan
-- 1. Berapa total revenue keseluruhan dari penjualan iPhone?
SELECT 
    SUM(Quantity * Price) AS total_revenue
FROM iphone_sales_dataset;

-- 2. Model iPhone apa yang paling banyak terjual?
SELECT
    iPhone_Model,
    SUM(Quantity) AS total_penjualan
FROM iphone_sales_dataset
GROUP BY iPhone_Model
ORDER BY total_penjualan DESC;

-- 3. Model iPhone mana yang menghasilkan revenue terbesar?
SELECT
    iPhone_Model,
    SUM(Quantity * Price) AS total_revenue
FROM iphone_sales_dataset
GROUP BY iPhone_Model
ORDER BY total_revenue DESC;

-- 4. Berapa rata-rata quantity pembelian per transaksi?
SELECT
    ROUND(AVG(Quantity), 2) AS rata_rata_quantity
FROM iphone_sales_dataset;

-- 5. Transaksi mana yang memiliki nilai penjualan tertinggi?
SELECT
    Order_ID,
    Customer_Name,
    iPhone_Model,
    Quantity,
    Price,
    (Quantity * Price) AS total_transaksi
FROM iphone_sales_dataset
ORDER BY total_transaksi DESC
LIMIT 10;

Analisis Customer
-- 1. Siapa customer dengan total pembelian terbesar?
SELECT
    Customer_Name,
    SUM(Quantity * Price) AS total_pembelian
FROM iphone_sales_dataset
GROUP BY Customer_Name
ORDER BY total_pembelian DESC
LIMIT 10;

-- 2. Negara mana yang memiliki jumlah transaksi terbanyak?
SELECT
    Country,
    COUNT(*) AS jumlah_transaksi
FROM iphone_sales_dataset
GROUP BY Country
ORDER BY jumlah_transaksi DESC;

-- 3. Negara mana yang memberikan kontribusi revenue terbesar?
SELECT
    Country,
    SUM(Quantity * Price) AS total_revenue
FROM iphone_sales_dataset
GROUP BY Country
ORDER BY total_revenue DESC;

Analisis Produk
-- 1. Storage iPhone apa yang paling diminati pelanggan?
SELECT
    Storage,
    SUM(Quantity) AS total_penjualan
FROM iphone_sales_dataset
GROUP BY Storage
ORDER BY total_penjualan DESC;

-- 2. Warna iPhone apa yang paling sering dibeli?
SELECT
    Color,
    SUM(Quantity) AS total_penjualan
FROM iphone_sales_dataset
GROUP BY Color
ORDER BY total_penjualan DESC;

-- 3. Kombinasi model dan storage mana yang paling populer?
SELECT
    iPhone_Model,
    Storage,
    SUM(Quantity) AS total_penjualan
FROM iphone_sales_dataset
GROUP BY iPhone_Model, Storage
ORDER BY total_penjualan DESC;

-- 4. Berapa rata-rata harga jual masing-masing model iPhone?
SELECT
    iPhone_Model,
    ROUND(AVG(Price), 2) AS rata_rata_harga
FROM iphone_sales_dataset
GROUP BY iPhone_Model
ORDER BY rata_rata_harga DESC;

Analisis Pembayaran
-- 1.  Metode pembayaran apa yang paling sering digunakan pelanggan?
SELECT
    Payment_Method,
    COUNT(*) AS total_penggunaan
FROM iphone_sales_dataset
GROUP BY Payment_Method
ORDER BY total_penggunaan DESC;

-- 2. Apakah terdapat perbedaan pola pembelian berdasarkan metode pembayaran?
SELECT
    Payment_Method,
    COUNT(*) AS jumlah_transaksi,
    SUM(Quantity) AS total_quantity,
    ROUND(AVG(Quantity), 2) AS rata_rata_quantity,
    SUM(Quantity * Price) AS total_revenue
FROM iphone_sales_dataset
GROUP BY Payment_Method
ORDER BY total_revenue DESC;

Analisis Waktu
-- 1. Bagaimana tren penjualan iPhone setiap bulan?
SELECT
    strftime('%Y-%m', Sale_Date) AS bulan,
    SUM(Quantity * Price) AS total_penjualan
FROM iphone_sales_dataset
GROUP BY bulan
ORDER BY bulan;

-- 2. Bulan apa yang memiliki revenue tertinggi?
SELECT
    strftime('%Y-%m', Sale_Date) AS bulan,
    SUM(Quantity * Price) AS total_revenue
FROM iphone_sales_dataset
GROUP BY bulan
ORDER BY total_revenue DESC
LIMIT 1;</sql><current_tab id="0"/></tab_sql></sqlb_project>
